# Seismic MCP Credentials
# Get these from https://apps.seismic.com
SEISMIC_CLIENT_ID=your_client_id_here
SEISMIC_CLIENT_SECRET=your_client_secret_here

# Optional: Override the default Seismic MCP URL
# SEISMIC_MCP_URL=https://mcp.seismic.com/tenants/your_tenant_name

# OpenAI API Key (Required for LangGraph summary)
OPENAI_API_KEY=your_openai_api_key_here

# Local SQLite Demo Credentials (optional)
# LOCAL_DB_PATH=test.db
